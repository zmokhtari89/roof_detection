    {
      "cell_type": "code",
      "source": [
        "import torch.nn.functional as F\n",
        "\n",
        "# Loss V1: BCE + Dice\n",
        "bce_loss = nn.BCEWithLogitsLoss()\n",
        "\n",
        "def dice_loss(pred, target, smooth=1.0):   # smooth avoids division by zero\n",
        "    pred   = torch.sigmoid(pred).view(-1)\n",
        "    target = target.view(-1)\n",
        "    intersection = (pred * target).sum()\n",
        "    return 1 - (2 * intersection + smooth) / (pred.sum() + target.sum() + smooth)\n",
        "\n",
        "def combined_loss_v1(pred, target):\n",
        "    \"\"\"BCE + Dice. Matches dida's published loss strategy.\"\"\"\n",
        "    return bce_loss(pred, target) + dice_loss(pred, target)\n",
        "\n",
        "# Loss V2: BCE + Dice + boundary weighting\n",
        "def boundary_loss(pred, target, lambda_boundary=0.5):\n",
        "    kernel    = torch.ones(1, 1, 5, 5, device=target.device)\n",
        "    dilated   = F.conv2d(target, kernel, padding=2).clamp(0, 1)\n",
        "    eroded    = 1 - F.conv2d(1 - target, kernel, padding=2).clamp(0, 1)\n",
        "    boundary  = (dilated - eroded).clamp(0, 1)\n",
        "    weighted_mse = (boundary * (torch.sigmoid(pred) - target) ** 2).mean()\n",
        "    return lambda_boundary * weighted_mse\n",
        "\n",
        "def combined_loss_v2(pred, target):\n",
        "    \"\"\"BCE + Dice + Boundary weighting. Inspired by dida's pixel-weighting approach.\"\"\"\n",
        "    return bce_loss(pred, target) + dice_loss(pred, target) + boundary_loss(pred, target)\n",
        "\n",
        "# Metrics: IoU, Dice, Recall\n",
        "def compute_metrics(pred, target, threshold=0.5):\n",
        "    pred_bin = (torch.sigmoid(pred) > threshold).float()\n",
        "    target   = target.float()\n",
        "    TP = (pred_bin * target).sum()\n",
        "    FP = (pred_bin * (1 - target)).sum()\n",
        "    FN = ((1 - pred_bin) * target).sum()\n",
        "    iou       = (TP + 1e-6) / (TP + FP + FN + 1e-6)\n",
        "    dice      = (2 * TP + 1e-6) / (2 * TP + FP + FN + 1e-6)\n",
        "    recall    = (TP + 1e-6) / (TP + FN + 1e-6)\n",
        "    return iou.item(), dice.item(), recall.item()\n",
        "\n",
        "# Training function\n",
        "def train_model(model, model_name, loss_fn, optimizer, num_epochs=200):\n",
        "    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
        "        optimizer, mode=\"min\", patience=10, factor=0.5\n",
        "    )\n",
        "    best_val_loss = float(\"inf\")\n",
        "    history = {\"train_loss\": [], \"val_loss\": [], \"val_iou\": [],\n",
        "               \"val_dice\": [], \"val_recall\": []}\n",
        "\n",
        "    for epoch in range(num_epochs):\n",
        "        model.train()\n",
        "        epoch_loss = 0\n",
        "        for images, masks in train_loader:\n",
        "            images, masks = images.to(DEVICE), masks.to(DEVICE)\n",
        "            optimizer.zero_grad()\n",
        "            loss = loss_fn(model(images), masks)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "            epoch_loss += loss.item()\n",
        "\n",
        "        avg_train_loss = epoch_loss / len(train_loader)\n",
        "\n",
        "        model.eval()\n",
        "        val_loss = val_iou = val_dice = val_rec = 0\n",
        "        with torch.no_grad():\n",
        "            for images, masks in val_loader:\n",
        "                images, masks = images.to(DEVICE), masks.to(DEVICE)\n",
        "                preds      = model(images)\n",
        "                val_loss  += loss_fn(preds, masks).item()\n",
        "                iou, dice, rec = compute_metrics(preds, masks)\n",
        "                val_iou   += iou\n",
        "                val_dice  += dice\n",
        "                val_rec   += rec\n",
        "\n",
        "        n = len(val_loader)\n",
        "        avg_val_loss = val_loss / n\n",
        "        scheduler.step(avg_val_loss)\n",
        "\n",
        "        history[\"train_loss\"].append(avg_train_loss)\n",
        "        history[\"val_loss\"].append(avg_val_loss)\n",
        "        history[\"val_iou\"].append(val_iou / n)\n",
        "        history[\"val_dice\"].append(val_dice / n)\n",
        "        history[\"val_recall\"].append(val_rec / n)\n",
        "\n",
        "        if avg_val_loss < best_val_loss:\n",
        "            best_val_loss = avg_val_loss\n",
        "            torch.save(model.state_dict(), f\"best_{model_name}.pth\")\n",
        "\n",
        "        if (epoch + 1) % 20 == 0:\n",
        "            print(f\"[{model_name}] Epoch {epoch+1:3d}/{num_epochs} | \"\n",
        "                  f\"Train: {avg_train_loss:.4f} | \"\n",
        "                  f\"Val: {avg_val_loss:.4f} | \"\n",
        "                  f\"IoU: {val_iou/n:.4f} | \"\n",
        "                  f\"Dice: {val_dice/n:.4f} | \"\n",
        "                  f\"Rec: {val_rec/n:.4f}\")\n",
        "\n",
        "    print(f\"\\n[{model_name}] Done. Best checkpoint → best_{model_name}.pth\")\n",
        "    return history"
      ],
      "metadata": {
        "id": "YwhhWZH8MrtQ"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "NUM_EPOCHS = 200\n",
        "\n",
        "def make_unet():\n",
        "    return smp.Unet(\n",
        "        encoder_name=\"resnet34\", encoder_weights=\"imagenet\",\n",
        "        in_channels=3, classes=1, activation=None\n",
        "    ).to(DEVICE)\n",
        "\n",
        "def make_unetpp():\n",
        "    return smp.UnetPlusPlus(\n",
        "        encoder_name=\"resnet34\", encoder_weights=\"imagenet\",\n",
        "        in_channels=3, classes=1, activation=None\n",
        "    ).to(DEVICE)\n",
        "\n",
        "# U-Net V1\n",
        "unet_v1 = make_unet()\n",
        "history_unet_v1 = train_model(\n",
        "    unet_v1, \"unet_v1\", combined_loss_v1,\n",
        "    torch.optim.Adam(unet_v1.parameters(), lr=1e-4), NUM_EPOCHS\n",
        ")\n",
