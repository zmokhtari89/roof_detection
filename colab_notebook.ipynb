        "model_best = make_unetpp()\n",
        "model_best.load_state_dict(torch.load(\"best_unetpp_v1.pth\", map_location=DEVICE))\n",
        "model_best.eval()\n",
        "\n",
        "transform = A.Compose([\n",
        "    A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),\n",
        "    ToTensorV2()\n",
        "])\n",
        "\n",
        "os.makedirs(\"predictions\", exist_ok=True)\n",
        "\n",
        "fig, axes = plt.subplots(5, 3, figsize=(12, 20))\n",
        "axes[0, 0].set_title(\"Original Image\",   fontsize=13)\n",
        "axes[0, 1].set_title(\"Predicted Mask\",   fontsize=13)\n",
        "axes[0, 2].set_title(\"Overlay\",          fontsize=13)\n",
        "\n",
        "for i, fname in enumerate(test_images):\n",
        "    image_np = np.array(Image.open(os.path.join(IMAGE_DIR, fname)).convert(\"RGB\"))\n",
        "    tensor   = transform(image=image_np)[\"image\"].unsqueeze(0).to(DEVICE)\n",
        "    with torch.no_grad():\n",
        "        pred   = torch.sigmoid(model_best(tensor)).squeeze().cpu().numpy()\n",
        "    binary = (pred > 0.5).astype(np.uint8)  # threshold: sigmoid output > 0.5 -> roof\n",
        "\n",
        "    Image.fromarray(binary * 255).save(\n",
        "        f\"predictions/{os.path.splitext(fname)[0]}_pred.png\"\n",
        "    )\n",
        "\n",
        "    overlay = image_np.copy().astype(float)\n",
        "    overlay[binary == 1] = np.array([255, 0, 0])\n",
        "    overlay = (0.6 * image_np + 0.4 * overlay).astype(np.uint8)\n",
        "\n",
        "    axes[i, 0].imshow(image_np);           axes[i, 0].set_ylabel(fname, fontsize=9); axes[i, 0].axis(\"off\")\n",
        "    axes[i, 1].imshow(binary, cmap=\"gray\");                                           axes[i, 1].axis(\"off\")\n",
        "    axes[i, 2].imshow(overlay);                                                        axes[i, 2].axis(\"off\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
